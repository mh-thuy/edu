generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  TEACHER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  fullName     String
  passwordHash String    @map("password_hash")
  role         Role
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  teacher      Teacher?

  @@map("users")
}

model Room {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  capacity       Int
  floor          Int             @default(1)
  location       String?
  status         String          @default("AVAILABLE")
  note           String?
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  classes        Class[]
  classSchedules ClassSchedule[]

  @@map("rooms")
}

model Teacher {
  id             String          @id @default(uuid())
  userId         String          @unique @map("user_id")
  code           String          @unique
  phone          String?
  email          String?         @unique
  bankAccount    String?         @map("bank_account")
  specialty      String?
  status         String          @default("ACTIVE")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes        Class[]
  classSchedules ClassSchedule[]

  @@map("teachers")
}

model Student {
  id            String         @id @default(uuid())
  code          String         @unique
  fullName      String         @map("full_name")
  email         String?        @unique
  phone         String?
  birthday      DateTime?
  parentName    String?        @map("parent_name")
  address       String?
  status        String         @default("ACTIVE")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  classStudents ClassStudent[]
  studentFees   StudentFee[]

  @@map("students")
}

model Class {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  teacherId      String?         @map("teacher_id")
  roomId         String?         @map("room_id")
  tuitionFee     Float           @default(0) @map("tuition_fee")
  totalSessions  Int             @default(0) @map("total_sessions")
  maxStudents    Int             @default(30) @map("max_students")
  startDate      DateTime?       @map("start_date")
  endDate        DateTime?       @map("end_date")
  status         String          @default("DRAFT")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  teacher        Teacher?        @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  room           Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull)
  classStudents  ClassStudent[]
  classSchedules ClassSchedule[]
  studentFees    StudentFee[]

  @@map("classes")
}

model ClassStudent {
  classId    String   @map("class_id")
  studentId  String   @map("student_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([classId, studentId])
  @@map("class_students")
}

model ClassSchedule {
  id        String   @id @default(uuid())
  classId   String   @map("class_id")
  roomId    String?  @map("room_id")
  teacherId String?  @map("teacher_id")
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  room      Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@map("class_schedules")
}

model StudentFee {
  id        String    @id @default(uuid())
  studentId String    @map("student_id")
  classId   String    @map("class_id")
  month     String    @map("month") // YYYY-MM format
  amount    Float
  dueDate   DateTime  @map("due_date")
  status    String    @default("unpaid") // unpaid, partial, paid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@unique([studentId, classId, month])
  @@map("student_fees")
}

model Payment {
  id         String    @id @default(uuid())
  studentFeeId String  @map("student_fee_id")
  amount     Float
  method     String    // cash, transfer, wallet
  paymentDate DateTime @map("payment_date")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  studentFee StudentFee @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  receipts   Receipt[]

  @@map("payments")
}

model Receipt {
  id             String   @id @default(uuid())
  paymentId      String   @unique @map("payment_id")
  receiptNumber  String   @unique @map("receipt_number")
  issueDate      DateTime @map("issue_date")
  printedAt      DateTime? @map("printed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  payment        Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

model ClassSalaryRule {
  id                  String   @id @default(uuid())
  classId             String   @unique @map("class_id")
  commissionPercentage Float   @map("commission_percentage") // Center's percentage (e.g., 12%)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("class_salary_rules")
}

model TeacherPayroll {
  id              String                @id @default(uuid())
  teacherId       String                @map("teacher_id")
  month           String                @map("month") // YYYY-MM format
  totalRevenue    Float                 @default(0) @map("total_revenue")
  centerFee       Float                 @default(0) @map("center_fee")
  salaryAmount    Float                 @default(0) @map("salary_amount")
  status          String                @default("draft") // draft, approved, paid
  approvedAt      DateTime?             @map("approved_at")
  paidAt          DateTime?             @map("paid_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  items           TeacherPayrollItem[]

  @@unique([teacherId, month])
  @@map("teacher_payrolls")
}

model TeacherPayrollItem {
  id        String        @id @default(uuid())
  payrollId String        @map("payroll_id")
  classId   String        @map("class_id")
  classCode String        @map("class_code")
  studentCount Int        @map("student_count")
  revenue   Float
  fee       Float
  salary    Float
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  payroll   TeacherPayroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@map("teacher_payroll_items")
}
