generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED

  @@map("user_status")
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE

  @@map("teacher_status")
}

enum StudentStatus {
  ACTIVE
  INACTIVE

  @@map("student_status")
}

enum RoomStatus {
  AVAILABLE
  MAINTENANCE
  UNAVAILABLE

  @@map("room_status")
}

enum ClassStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("class_status")
}

enum EnrollmentStatus {
  ACTIVE
  LEFT
  COMPLETED
  SUSPENDED

  @@map("enrollment_status")
}

enum FeeStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED

  @@map("fee_status")
}

enum PaymentRequestStatus {
  ACTIVE
  EXPIRED
  PAID
  CANCELLED

  @@map("payment_request_status")
}

enum PaymentQrStatus {
  ACTIVE
  EXPIRED
  CANCELLED

  @@map("payment_qr_status")
}

enum PaymentMethod {
  CASH
  TRANSFER
  WALLET

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  FAILED

  @@map("payment_status")
}

enum PaymentNoticeStatus {
  DRAFT
  GENERATED
  PRINTED
  SENT
  CANCELLED

  @@map("payment_notice_status")
}

enum ReceiptStatus {
  ACTIVE
  CANCELLED

  @@map("receipt_status")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  MAKEUP

  @@map("attendance_status")
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED

  @@map("payroll_status")
}

enum ExpenseStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED

  @@map("expense_status")
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique(map: "uq_users_email") @db.VarChar(255)
  fullName     String     @map("full_name") @db.VarChar(255)
  passwordHash String     @map("password_hash")
  status       UserStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  roles   UserRole[]
  teacher Teacher?

  @@map("users")
}

model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique(map: "uq_roles_code") @db.VarChar(50)
  name        String  @db.VarChar(255)
  description String?
  isActive    Boolean @default(true) @map("is_active")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique(map: "uq_permissions_code") @db.VarChar(100)
  name        String  @db.VarChar(255)
  resource    String  @db.VarChar(100)
  action      String  @db.VarChar(50)
  description String?
  isActive    Boolean @default(true) @map("is_active")

  roles RolePermission[]

  @@index([resource, action], map: "idx_permissions_resource_action")
  @@map("permissions")
}

model UserRole {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], map: "fk_user_roles_user")
  role Role @relation(fields: [roleId], references: [id], map: "fk_user_roles_role")

  @@unique([userId, roleId], map: "uq_user_roles_user_role")
  @@map("user_roles")
}

model RolePermission {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String  @map("role_id") @db.Uuid
  permissionId String  @map("permission_id") @db.Uuid
  isAllowed    Boolean @default(true) @map("is_allowed")

  role       Role       @relation(fields: [roleId], references: [id], map: "fk_role_permissions_role")
  permission Permission @relation(fields: [permissionId], references: [id], map: "fk_role_permissions_permission")

  @@unique([roleId, permissionId], map: "uq_role_permissions_role_permission")
  @@map("role_permissions")
}

model Teacher {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String        @unique(map: "uq_teachers_code") @db.VarChar(50)
  userId      String?       @unique(map: "uq_teachers_user_id") @map("user_id") @db.Uuid
  fullName    String        @map("full_name") @db.VarChar(255)
  email       String?       @unique(map: "uq_teachers_email") @db.VarChar(255)
  phone       String?       @db.VarChar(50)
  bankAccount String?       @map("bank_account") @db.VarChar(100)
  specialty   String?       @db.VarChar(255)
  status      TeacherStatus @default(ACTIVE)
  note        String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  user      User?            @relation(fields: [userId], references: [id], map: "fk_teachers_user")
  classes   Class[]
  schedules ClassSchedule[]
  payrolls  TeacherPayroll[]

  @@map("teachers")
}

model Student {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String        @unique(map: "uq_students_code") @db.VarChar(50)
  fullName   String        @map("full_name") @db.VarChar(255)
  email      String?       @unique(map: "uq_students_email") @db.VarChar(255)
  phone      String?       @db.VarChar(50)
  birthday   DateTime?     @db.Date
  parentName String?       @map("parent_name") @db.VarChar(255)
  address    String?
  status     StudentStatus @default(ACTIVE)
  note       String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  enrollments ClassStudent[]
  fees        StudentFee[]
  attendances Attendance[]

  @@map("students")
}

model Room {
  id       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code     String     @unique(map: "uq_rooms_code") @db.VarChar(50)
  name     String     @db.VarChar(255)
  capacity Int        @default(0)
  floor    String?    @db.VarChar(50)
  location String?    @db.VarChar(255)
  status   RoomStatus @default(AVAILABLE)
  note     String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  classes   Class[]
  schedules ClassSchedule[]

  @@map("rooms")
}

model Class {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String      @unique(map: "uq_classes_code") @db.VarChar(50)
  name          String      @db.VarChar(255)
  teacherId     String?     @map("teacher_id") @db.Uuid
  roomId        String?     @map("room_id") @db.Uuid
  tuitionFee    Decimal     @default(0) @map("tuition_fee") @db.Decimal(12, 2)
  totalSessions Int         @default(0) @map("total_sessions")
  maxStudents   Int         @default(0) @map("max_students")
  startDate     DateTime?   @map("start_date") @db.Date
  endDate       DateTime?   @map("end_date") @db.Date
  status        ClassStatus @default(DRAFT)
  note          String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  teacher      Teacher?             @relation(fields: [teacherId], references: [id], map: "fk_classes_teacher")
  room         Room?                @relation(fields: [roomId], references: [id], map: "fk_classes_room")
  students     ClassStudent[]
  schedules    ClassSchedule[]
  attendances  Attendance[]
  fees         StudentFee[]
  salaryRule   ClassSalaryRule?
  payrollItems TeacherPayrollItem[]

  @@index([teacherId], map: "idx_classes_teacher_id")
  @@index([roomId], map: "idx_classes_room_id")
  @@index([status], map: "idx_classes_status")
  @@map("classes")
}

model ClassStudent {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classId    String           @map("class_id") @db.Uuid
  studentId  String           @map("student_id") @db.Uuid
  enrolledAt DateTime         @default(dbgenerated("CURRENT_DATE")) @map("enrolled_at") @db.Date
  leftAt     DateTime?        @map("left_at") @db.Date
  status     EnrollmentStatus @default(ACTIVE)
  note       String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  class   Class   @relation(fields: [classId], references: [id], map: "fk_class_students_class")
  student Student @relation(fields: [studentId], references: [id], map: "fk_class_students_student")

  @@unique([classId, studentId], map: "uq_class_students_class_student")
  @@index([classId], map: "idx_class_students_class_id")
  @@index([studentId], map: "idx_class_students_student_id")
  @@map("class_students")
}

model ClassSchedule {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classId     String  @map("class_id") @db.Uuid
  roomId      String  @map("room_id") @db.Uuid
  teacherId   String  @map("teacher_id") @db.Uuid
  dayOfWeek   Int     @map("day_of_week") @db.SmallInt
  startMinute Int     @map("start_minute")
  endMinute   Int     @map("end_minute")
  note        String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  class       Class        @relation(fields: [classId], references: [id], map: "fk_class_schedules_class")
  room        Room         @relation(fields: [roomId], references: [id], map: "fk_class_schedules_room")
  teacher     Teacher      @relation(fields: [teacherId], references: [id], map: "fk_class_schedules_teacher")
  attendances Attendance[]

  @@index([classId], map: "idx_class_schedules_class_id")
  @@index([roomId, dayOfWeek], map: "idx_class_schedules_room_day")
  @@index([teacherId, dayOfWeek], map: "idx_class_schedules_teacher_day")
  @@map("class_schedules")
}

model Attendance {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classId        String           @map("class_id") @db.Uuid
  studentId      String           @map("student_id") @db.Uuid
  scheduleId     String?          @map("schedule_id") @db.Uuid
  attendanceDate DateTime         @map("attendance_date") @db.Date
  status         AttendanceStatus @default(PRESENT)
  note           String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  class    Class          @relation(fields: [classId], references: [id], map: "fk_attendances_class")
  student  Student        @relation(fields: [studentId], references: [id], map: "fk_attendances_student")
  schedule ClassSchedule? @relation(fields: [scheduleId], references: [id], map: "fk_attendances_schedule")

  @@unique([classId, studentId, attendanceDate], map: "uq_attendances_class_student_date")
  @@index([classId, attendanceDate], map: "idx_attendances_class_date")
  @@index([studentId], map: "idx_attendances_student_id")
  @@map("attendances")
}

model StudentFee {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId         String    @map("student_id") @db.Uuid
  classId           String    @map("class_id") @db.Uuid
  billingYear       Int       @map("billing_year")
  billingMonth      Int       @map("billing_month") @db.SmallInt
  amount            Decimal   @default(0) @db.Decimal(12, 2)
  discount          Decimal   @default(0) @db.Decimal(12, 2)
  finalAmount       Decimal   @default(0) @map("final_amount") @db.Decimal(12, 2)
  paidAmount        Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  outstandingAmount Decimal   @default(0) @map("outstanding_amount") @db.Decimal(12, 2)
  dueDate           DateTime? @map("due_date") @db.Date
  status            FeeStatus @default(UNPAID)
  note              String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  student Student @relation(fields: [studentId], references: [id], map: "fk_student_fees_student")
  class   Class   @relation(fields: [classId], references: [id], map: "fk_student_fees_class")

  paymentRequests PaymentRequest[]
  payments        Payment[]

  @@unique([studentId, classId, billingYear, billingMonth], map: "uq_student_fees_student_class_month")
  @@index([studentId], map: "idx_student_fees_student_id")
  @@index([classId], map: "idx_student_fees_class_id")
  @@index([billingYear, billingMonth], map: "idx_student_fees_billing_month")
  @@index([status], map: "idx_student_fees_status")
  @@map("student_fees")
}

model PaymentAccount {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String  @unique(map: "uq_payment_accounts_code") @db.VarChar(50)
  bankCode      String  @map("bank_code") @db.VarChar(50)
  bankName      String  @map("bank_name") @db.VarChar(100)
  accountNumber String  @map("account_number") @db.VarChar(100)
  accountName   String  @map("account_name") @db.VarChar(255)
  isDefault     Boolean @default(false) @map("is_default")
  isActive      Boolean @default(true) @map("is_active")
  note          String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  paymentRequests PaymentRequest[]

  @@unique([bankCode, accountNumber], map: "uq_payment_accounts_bank_account")
  @@index([isActive], map: "idx_payment_accounts_active")
  @@map("payment_accounts")
}

model PaymentRequest {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentFeeId     String               @map("student_fee_id") @db.Uuid
  paymentAccountId String               @map("payment_account_id") @db.Uuid
  paymentCode      String               @unique(map: "uq_payment_requests_payment_code") @map("payment_code") @db.VarChar(100)
  requestedAmount  Decimal              @map("requested_amount") @db.Decimal(12, 2)
  transferContent  String               @map("transfer_content") @db.VarChar(255)
  expiredAt        DateTime?            @map("expired_at") @db.Timestamptz(6)
  status           PaymentRequestStatus @default(ACTIVE)
  note             String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentFee     StudentFee     @relation(fields: [studentFeeId], references: [id], map: "fk_payment_requests_student_fee")
  paymentAccount PaymentAccount @relation(fields: [paymentAccountId], references: [id], map: "fk_payment_requests_payment_account")

  qrCode   PaymentQrCode?
  notices  PaymentNotice[]
  payments Payment[]

  @@index([studentFeeId], map: "idx_payment_requests_student_fee_id")
  @@index([paymentAccountId], map: "idx_payment_requests_payment_account_id")
  @@index([status], map: "idx_payment_requests_status")
  @@map("payment_requests")
}

model PaymentQrCode {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentRequestId String          @unique(map: "uq_payment_qr_codes_payment_request_id") @map("payment_request_id") @db.Uuid
  qrPayload        String          @map("qr_payload")
  status           PaymentQrStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  paymentRequest PaymentRequest @relation(fields: [paymentRequestId], references: [id], map: "fk_payment_qr_codes_payment_request")

  @@index([status], map: "idx_payment_qr_codes_status")
  @@map("payment_qr_codes")
}

model PaymentNotice {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentRequestId String              @map("payment_request_id") @db.Uuid
  noticeNumber     String              @unique(map: "uq_payment_notices_notice_number") @map("notice_number") @db.VarChar(100)
  amount           Decimal             @db.Decimal(12, 2)
  dueDate          DateTime?           @map("due_date") @db.Date
  pdfUrl           String?             @map("pdf_url")
  version          Int                 @default(1)
  isLatest         Boolean             @default(true) @map("is_latest")
  printedAt        DateTime?           @map("printed_at") @db.Timestamptz(6)
  sentAt           DateTime?           @map("sent_at") @db.Timestamptz(6)
  sendMethod       String?             @map("send_method") @db.VarChar(50)
  status           PaymentNoticeStatus @default(DRAFT)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  paymentRequest PaymentRequest @relation(fields: [paymentRequestId], references: [id], map: "fk_payment_notices_payment_request")

  @@unique([paymentRequestId, version], map: "uq_payment_notices_request_version")
  @@index([paymentRequestId], map: "idx_payment_notices_payment_request_id")
  @@index([status], map: "idx_payment_notices_status")
  @@map("payment_notices")
}

model BankTransaction {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bankCode        String    @map("bank_code") @db.VarChar(50)
  transactionId   String    @unique(map: "uq_bank_transactions_transaction_id") @map("transaction_id") @db.VarChar(255)
  amount          Decimal   @db.Decimal(12, 2)
  transactionDate DateTime  @map("transaction_date") @db.Timestamptz(6)
  description     String?
  referenceCode   String?   @map("reference_code") @db.VarChar(100)
  rawData         Json?     @map("raw_data")
  matched         Boolean   @default(false)
  matchedAt       DateTime? @map("matched_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  payments Payment[]

  @@index([bankCode], map: "idx_bank_transactions_bank_code")
  @@index([referenceCode], map: "idx_bank_transactions_reference_code")
  @@index([transactionDate], map: "idx_bank_transactions_transaction_date")
  @@index([matched], map: "idx_bank_transactions_matched")
  @@map("bank_transactions")
}

model Payment {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentFeeId      String        @map("student_fee_id") @db.Uuid
  paymentRequestId  String?       @map("payment_request_id") @db.Uuid
  bankTransactionId String?       @map("bank_transaction_id") @db.Uuid
  amount            Decimal       @db.Decimal(12, 2)
  method            PaymentMethod
  paymentDate       DateTime      @default(dbgenerated("CURRENT_DATE")) @map("payment_date") @db.Date
  status            PaymentStatus @default(PENDING)
  notes             String?

  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  confirmedAt  DateTime? @map("confirmed_at") @db.Timestamptz(6)
  cancelledAt  DateTime? @map("cancelled_at") @db.Timestamptz(6)
  cancelReason String?   @map("cancel_reason")

  studentFee      StudentFee       @relation(fields: [studentFeeId], references: [id], map: "fk_payments_student_fee")
  paymentRequest  PaymentRequest?  @relation(fields: [paymentRequestId], references: [id], map: "fk_payments_payment_request")
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id], map: "fk_payments_bank_transaction")
  receipt         Receipt?

  @@index([studentFeeId], map: "idx_payments_student_fee_id")
  @@index([paymentRequestId], map: "idx_payments_payment_request_id")
  @@index([bankTransactionId], map: "idx_payments_bank_transaction_id")
  @@index([paymentDate], map: "idx_payments_payment_date")
  @@index([method], map: "idx_payments_method")
  @@index([status], map: "idx_payments_status")
  @@map("payments")
}

model Receipt {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId     String        @unique(map: "uq_receipts_payment_id") @map("payment_id") @db.Uuid
  receiptNumber String        @unique(map: "uq_receipts_receipt_number") @map("receipt_number") @db.VarChar(100)
  issueDate     DateTime      @default(dbgenerated("CURRENT_DATE")) @map("issue_date") @db.Date
  printedAt     DateTime?     @map("printed_at") @db.Timestamptz(6)
  status        ReceiptStatus @default(ACTIVE)

  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  cancelledAt  DateTime? @map("cancelled_at") @db.Timestamptz(6)
  cancelReason String?   @map("cancel_reason")

  payment Payment @relation(fields: [paymentId], references: [id], map: "fk_receipts_payment")

  @@index([issueDate], map: "idx_receipts_issue_date")
  @@index([status], map: "idx_receipts_status")
  @@map("receipts")
}

model Expense {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String        @unique(map: "uq_expenses_code") @db.VarChar(50)
  title       String        @db.VarChar(255)
  category    String?       @db.VarChar(100)
  amount      Decimal       @db.Decimal(12, 2)
  expenseDate DateTime      @map("expense_date") @db.Date
  status      ExpenseStatus @default(DRAFT)
  note        String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([expenseDate], map: "idx_expenses_expense_date")
  @@index([status], map: "idx_expenses_status")
  @@map("expenses")
}

model ClassSalaryRule {
  id                     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classId                String  @unique(map: "uq_class_salary_rules_class_id") @map("class_id") @db.Uuid
  teacherSharePercentage Decimal @default(0) @map("teacher_share_percentage") @db.Decimal(5, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  class Class @relation(fields: [classId], references: [id], map: "fk_class_salary_rules_class")

  @@map("class_salary_rules")
}

model TeacherPayroll {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId    String        @map("teacher_id") @db.Uuid
  billingYear  Int           @map("billing_year")
  billingMonth Int           @map("billing_month") @db.SmallInt
  totalRevenue Decimal       @default(0) @map("total_revenue") @db.Decimal(12, 2)
  centerFee    Decimal       @default(0) @map("center_fee") @db.Decimal(12, 2)
  salaryAmount Decimal       @default(0) @map("salary_amount") @db.Decimal(12, 2)
  status       PayrollStatus @default(DRAFT)
  approvedAt   DateTime?     @map("approved_at") @db.Timestamptz(6)
  paidAt       DateTime?     @map("paid_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher Teacher              @relation(fields: [teacherId], references: [id], map: "fk_teacher_payrolls_teacher")
  items   TeacherPayrollItem[]

  @@unique([teacherId, billingYear, billingMonth], map: "uq_teacher_payrolls_teacher_month")
  @@index([billingYear, billingMonth], map: "idx_teacher_payrolls_billing_month")
  @@index([status], map: "idx_teacher_payrolls_status")
  @@map("teacher_payrolls")
}

model TeacherPayrollItem {
  id                     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollId              String  @map("payroll_id") @db.Uuid
  classId                String  @map("class_id") @db.Uuid
  classCode              String  @map("class_code") @db.VarChar(50)
  className              String  @map("class_name") @db.VarChar(255)
  studentCount           Int     @default(0) @map("student_count")
  revenue                Decimal @default(0) @db.Decimal(12, 2)
  teacherSharePercentage Decimal @default(0) @map("teacher_share_percentage") @db.Decimal(5, 2)
  salary                 Decimal @default(0) @db.Decimal(12, 2)
  centerFee              Decimal @default(0) @map("center_fee") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  payroll TeacherPayroll @relation(fields: [payrollId], references: [id], map: "fk_teacher_payroll_items_payroll")
  class   Class          @relation(fields: [classId], references: [id], map: "fk_teacher_payroll_items_class")

  @@unique([payrollId, classId], map: "uq_teacher_payroll_items_payroll_class")
  @@index([payrollId], map: "idx_teacher_payroll_items_payroll_id")
  @@index([classId], map: "idx_teacher_payroll_items_class_id")
  @@map("teacher_payroll_items")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  tableName String   @map("table_name") @db.VarChar(100)
  recordId  String?  @map("record_id") @db.Uuid
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address") @db.Inet
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_audit_logs_user_id")
  @@index([action], map: "idx_audit_logs_action")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([tableName, recordId], map: "idx_audit_logs_table_record")
  @@map("audit_logs")
}
